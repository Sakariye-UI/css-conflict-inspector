{
  "manifest_version": 3,
  "name": "CSS Conflict Inspector",
  "version": "1.8.0",
  "description": "Detect which CSS rules on a page are breaking or hiding Klaviyo signup forms, review widgets, and customer agent components.",
  "permissions": ["activeTab", "scripting", "storage", "sidePanel", "debugger", "tabs"],
  "host_permissions": ["https://a.klaviyo.com/*", "<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "CSS Conflict Inspector"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
